# Telegram Bot (from @BotFather — free)
TELEGRAM_BOT_TOKEN=1234567890:AAHfiqksKZ8WmR2zSjiQ7_v4TMAKdiHm9T0
TELEGRAM_WEBHOOK_SECRET=any-random-string-you-choose

# Your Railway service public URL (set AFTER you deploy, so the app can register the webhook)
APP_URL=https://your-telegram-bridge.up.railway.app

# Backend API (same values as whatsapp-bridge)
CHAT_API_URL=https://mindmirror-production.up.railway.app/api/v1
API_KEY=ak_your_existing_api_key_here
USER_ID=your-supabase-user-uuid-here

# Daily briefing (proactive morning message)
# TELEGRAM_CHAT_ID: your personal chat ID — send any message to the bot first,
#   then check Railway logs for "Received from chat <ID>" to find it.
TELEGRAM_CHAT_ID=your-telegram-chat-id-here
BRIEFING_TIME=08:00
BRIEFING_TIMEZONE=America/New_York
